{
    "name": "braid",
    "version": "1.0.0",
    "description": "A Language-Agnostic Co-routine Framework - weave independent asynchronous strands into synchronized cords",
    "author": "ConflictingTheories",
    "license": "MIT",
    "homepage": "https://github.com/ConflictingTheories/braid",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ConflictingTheories/braid.git"
    },
    "keywords": [
        "async",
        "generator",
        "coroutine",
        "weave",
        "braid",
        "concurrency",
        "stream",
        "asynciterator"
    ],
    "type": "module",
    "main": "./dist/braid.cjs",
    "module": "./dist/braid.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/braid.js",
            "require": "./dist/braid.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "test": "ts-node braid.demo.ts"
    },
    "devDependencies": {
        "typescript": "^5.3.0",
        "vite": "^5.0.0"
    }
}
